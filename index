  {conf:"CONMEBOL",name:"Argentina",flag:"🇦🇷"},{conf:"CONMEBOL",name:"Bolivia",flag:"🇧🇴"},{conf:"CONMEBOL",name:"Brasil",flag:"🇧🇷"},{conf:"CONMEBOL",name:"Chile",flag:"🇨🇱"},{conf:"CONMEBOL",name:"Colombia",flag:"🇨🇴"},{conf:"CONMEBOL",name:"Ecuador",flag:"🇪🇨"},{conf:"CONMEBOL",name:"Paraguay",flag:"🇵🇾"},{conf:"CONMEBOL",name:"Perú",flag:"🇵🇪"},{conf:"CONMEBOL",name:"Uruguay",flag:"🇺🇾"},{conf:"CONMEBOL",name:"Venezuela",flag:"🇻🇪"},
  {conf:"OFC",name:"Nueva Zelanda",flag:"🇳🇿"},
  {conf:"UEFA",name:"Albania",flag:"🇦🇱"},{conf:"UEFA",name:"Austria",flag:"🇦🇹"},{conf:"UEFA",name:"Bélgica",flag:"🇧🇪"},{conf:"UEFA",name:"Croacia",flag:"🇭🇷"},{conf:"UEFA",name:"República Checa",flag:"🇨🇿"},{conf:"UEFA",name:"Dinamarca",flag:"🇩🇰"},{conf:"UEFA",name:"Inglaterra",flag:"🏴󠁧󠁢󠁥󠁮󠁧󠁿"},{conf:"UEFA",name:"Francia",flag:"🇫🇷"},{conf:"UEFA",name:"Alemania",flag:"🇩🇪"},{conf:"UEFA",name:"Hungría",flag:"🇭🇺"},{conf:"UEFA",name:"Italia",flag:"🇮🇹"},{conf:"UEFA",name:"Países Bajos",flag:"🇳🇱"},{conf:"UEFA",name:"Polonia",flag:"🇵🇱"},{conf:"UEFA",name:"Portugal",flag:"🇵🇹"},{conf:"UEFA",name:"Rumania",flag:"🇷🇴"},{conf:"UEFA",name:"Escocia",flag:"🏴󠁧󠁢󠁳󠁣󠁴󠁿"},{conf:"UEFA",name:"Serbia",flag:"🇷🇸"},{conf:"UEFA",name:"Eslovaquia",flag:"🇸🇰"},{conf:"UEFA",name:"Eslovenia",flag:"🇸🇮"},{conf:"UEFA",name:"España",flag:"🇪🇸"},{conf:"UEFA",name:"Suiza",flag:"🇨🇭"},{conf:"UEFA",name:"Turquía",flag:"🇹🇷"},{conf:"UEFA",name:"Ucrania",flag:"🇺🇦"},{conf:"UEFA",name:"Gales",flag:"🏴󠁧󠁢󠁷󠁬󠁳󠁿"}
];

const CONF_LABELS = {AFC:"Asia (AFC)",CAF:"África (CAF)",CONCACAF:"Norteamérica y Centroamérica (CONCACAF)",CONMEBOL:"Sudamérica (CONMEBOL)",OFC:"Oceanía (OFC)",UEFA:"Europa (UEFA)"};
const SLOT_LABELS = ["Campeón","Subcampeón","Tercer lugar","Cuarto lugar"];

let picks = [null,null,null,null];
let currentSlot = null;
let entries = [];

function setSyncStatus(status, count) {
  const dot = document.getElementById('syncDot');
  const label = document.getElementById('syncLabel');
  const countEl = document.getElementById('syncCount');
  dot.className = 'sync-dot ' + (status === 'live' ? 'live' : status === 'saving' ? 'saving' : status === 'error' ? 'error' : '');
  label.textContent = {loading:'Conectando…',live:'En vivo · compartido',saving:'Guardando…',error:'Sin conexión'}[status];
  countEl.textContent = (status === 'live' && count !== undefined) ? `· ${count} ${count===1?'participante':'participantes'}` : '';
}

async function loadEntries() {
  try {
    const res = await fetch(API_URL, {headers: HEADERS});
    if (!res.ok) throw new Error();
    const data = await res.json();
    entries = data.entries || [];
    setSyncStatus('live', entries.length);
    return entries;
  } catch {
    setSyncStatus('error');
    return [];
  }
}

async function saveEntries(updated) {
  const res = await fetch(API_URL, {
    method: 'PUT',
    headers: HEADERS,
    body: JSON.stringify({entries: updated})
  });
  if (!res.ok) throw new Error();
}

function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('view-' + tab).classList.add('active');
  if (tab === 'board') loadEntries().then(renderLeaderboard);
}

function openModal(slot) {
  currentSlot = slot;
  document.getElementById('modalTitle').textContent = 'Selecciona: ' + SLOT_LABELS[slot];
  document.getElementById('modalSearch').value = '';
  renderTeams('');
  document.getElementById('modalOverlay').classList.add('open');
  setTimeout(() => document.getElementById('modalSearch').focus(), 300);
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  currentSlot = null;
}

function closeModalOutside(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
}

function filterTeams() {
  renderTeams(document.getElementById('modalSearch').value);
}

function renderTeams(query) {
  const q = query.toLowerCase();
  const filtered = TEAMS.filter(t => t.name.toLowerCase().includes(q));
  const confs = [...new Set(TEAMS.map(t => t.conf))].sort();
  const body = document.getElementById('modalBody');
  body.innerHTML = '';
  confs.forEach(conf => {
    const list = filtered.filter(t => t.conf === conf);
    if (!list.length) return;
    const sec = document.createElement('div');
    sec.innerHTML = `<div class="conf-label">${CONF_LABELS[conf]}</div>`;
    const grid = document.createElement('div');
    grid.className = 'teams-list';
    list.forEach(team => {
      const alreadyPicked = picks.includes(team.name) && picks[currentSlot] !== team.name;
      const isSelected = picks[currentSlot] === team.name;
      const btn = document.createElement('button');
      btn.className = `team-btn${isSelected?' selected':''}${alreadyPicked?' dimmed':''}`;
      btn.innerHTML = `<span class="team-btn-flag">${team.flag}</span><span class="team-btn-name">${team.name}</span>`;
      btn.onclick = () => selectTeam(team);
      grid.appendChild(btn);
    });
    sec.appendChild(grid);
    body.appendChild(sec);
  });
  if (!filtered.length) body.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-muted);font-size:14px;">Ningún equipo coincide con tu búsqueda</div>';
}

function selectTeam(team) {
  picks[currentSlot] = team.name;
  updatePickDisplay(currentSlot, team);
  updateTiebreakerTeams();
  closeModal();
}

function updatePickDisplay(slot, team) {
  const display = document.getElementById('pick-display-' + slot);
  const btn = document.getElementById('pick-btn-' + slot);
  const existing = document.getElementById('clear-' + slot);
  if (existing) existing.remove();
  if (team) {
    display.innerHTML = `<span class="team-flag">${team.flag}</span><span class="team-name">${team.name}</span>`;
    btn.textContent = 'Cambiar equipo';
    btn.classList.add('has-pick');
    const clearBtn = document.createElement('button');
    clearBtn.className = 'clear-btn';
    clearBtn.id = 'clear-' + slot;
    clearBtn.textContent = '✕ Quitar';
    clearBtn.onclick = () => { picks[slot]=null; updatePickDisplay(slot,null); updateTiebreakerTeams(); };
    btn.after(clearBtn);
  } else {
    display.innerHTML = '<span class="pick-placeholder">Elige un equipo</span>';
    btn.textContent = 'Elegir equipo';
    btn.classList.remove('has-pick');
  }
}

function updateTiebreakerTeams() {
  const t0 = picks[0] ? TEAMS.find(t=>t.name===picks[0]) : null;
  const t1 = picks[1] ? TEAMS.find(t=>t.name===picks[1]) : null;
  document.getElementById('tb-team0').innerHTML = t0 ? `<span class="tb-flag">${t0.flag}</span><span class="tb-name">${t0.name}</span>` : '<span class="tb-flag">🏆</span><span class="tb-name">Campeón</span>';
  document.getElementById('tb-team1').innerHTML = t1 ? `<span class="tb-flag">${t1.flag}</span><span class="tb-name">${t1.name}</span>` : '<span class="tb-flag">🏅</span><span class="tb-name">Subcampeón</span>';
}

async function submitEntry() {
  const name = document.getElementById('playerName').value.trim();
  if (!name) { showToast('¡Escribe tu nombre primero!'); return; }
  if (picks.filter(Boolean).length < 4) { showToast('¡Elige los 4 semifinalistas!'); return; }
  setSyncStatus('saving');
  const entry = {
    id: Date.now(), nombre: name, picks: [...picks],
    marcador: [parseInt(document.getElementById('tb-score0').value)||null, parseInt(document.getElementById('tb-score1').value)||null],
    goleador: document.getElementById('topScorer').value.trim(),
    fecha: new Date().toLocaleDateString('es-CO',{month:'short',day:'numeric'})
  };
  try {
    const current = await loadEntries();
    const updated = [...current, entry];
    await saveEntries(updated);
    entries = updated;
    setSyncStatus('live', entries.length);
    showToast('✓ ¡Picks enviados! Mucha suerte.');
    document.getElementById('playerName').value = '';
    picks = [null,null,null,null];
    [0,1,2,3].forEach(i => updatePickDisplay(i,null));
    document.getElementById('tb-score0').value = '';
    document.getElementById('tb-score1').value = '';
    document.getElementById('topScorer').value = '';
    updateTiebreakerTeams();
    setTimeout(() => { document.querySelectorAll('.tab')[1].click(); }, 1200);
  } catch {
    setSyncStatus('error');
    showToast('Error al guardar. Intenta de nuevo.');
  }
}

function renderLeaderboard() {
  const list = document.getElementById('leaderboard-list');
  if (!entries.length) {
    list.innerHTML = '<div class="lb-empty"><div class="big-icon">📋</div><p>Aún no hay participantes.<br>¡Sé el primero en enviar tus picks!</p></div>';
    return;
  }
  list.innerHTML = '';
  [...entries].reverse().forEach((entry, idx) => {
    const pos = idx+1;
    const posClass = pos===1?'p1':pos===2?'p2':pos===3?'p3':'';
    const posSymbol = pos===1?'🥇':pos===2?'🥈':pos===3?'🥉':pos;
    const hasFinal = entry.marcador?.[0]!=null && entry.marcador?.[1]!=null;
    const picksHTML = entry.picks.map(p => {
      const t = TEAMS.find(t=>t.name===p);
      return `<div class="entry-pick"><span class="entry-pick-flag">${t?t.flag:'?'}</span><span class="entry-pick-name">${p}</span></div>`;
    }).join('');
    const extrasHTML = [
      hasFinal ? `<div class="extra-item"><span class="extra-label">Final:</span>${entry.marcador[0]}–${entry.marcador[1]}</div>` : '',
      entry.goleador ? `<div class="extra-item"><span class="extra-label">Goleador:</span>${entry.goleador}</div>` : ''
    ].join('');
    const card = document.createElement('div');
    card.className = 'entry-card';
    card.style.animationDelay = (idx*0.05)+'s';
    card.innerHTML = `
      <div class="entry-header">
        <div class="entry-rank-name">
          <div class="entry-pos ${posClass}">${posSymbol}</div>
          <div><div class="entry-name">${entry.nombre}</div><div class="entry-date">Enviado el ${entry.fecha}</div></div>
        </div>
        <div><div class="entry-points">— pts</div><div class="entry-pts-label">PENDIENTE</div></div>
      </div>
      <div class="entry-picks">${picksHTML}</div>
      ${(hasFinal||entry.goleador)?`<div class="entry-extras">${extrasHTML}</div>`:''}
    `;
    list.appendChild(card);
  });
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

loadEntries();
</script>
</body>
</html>
